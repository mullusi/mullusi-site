{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mullusi.com/schemas/privacy-policy.schema.json",
  "title": "Mullusi Product Privacy Policy",
  "description": "Purpose: define product-local data classes, user boundary, retention reference, and collection limits. Governance scope: privacy gate and data-flow admissibility. Invariants: no user-facing data flow exists without a declared class, boundary, and retention policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "productId",
    "purpose",
    "dataClasses",
    "userBoundary",
    "retentionPolicy",
    "collectionState"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "productId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "dataClasses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      },
      "uniqueItems": true
    },
    "userBoundary": {
      "type": "string",
      "minLength": 1
    },
    "retentionPolicy": {
      "type": "string",
      "pattern": "^privacy/[a-z0-9-]+\\.retention\\.json$"
    },
    "collectionState": {
      "type": "string",
      "enum": ["not-active", "limited-preview", "production"]
    }
  }
}

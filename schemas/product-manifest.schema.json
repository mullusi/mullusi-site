{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mullusi.com/schemas/product-manifest.schema.json",
  "title": "Mullusi Product Manifest",
  "description": "Purpose: define the authoritative product record used to generate public registries, status records, proof references, and release checklists. Governance scope: product identity, surfaces, runtime boundary, API contracts, data classes, proof boundary, release gates, and generated artifact controls. Invariants: no public product exposure is derived outside this manifest authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "summary",
    "family",
    "category",
    "status",
    "ownership",
    "surfaces",
    "runtime",
    "api",
    "data",
    "proof",
    "presentation",
    "releaseGate",
    "generation"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "private-incubation",
        "internal-alpha",
        "limited-preview",
        "public-beta",
        "production",
        "archived"
      ]
    },
    "ownership": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "supportEmail"],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "supportEmail": {
          "type": "string",
          "pattern": "^[^@\\s]+@mullusi\\.com$"
        }
      }
    },
    "surfaces": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publicRoute",
        "docsRoute",
        "dashboardRoute",
        "proofRoute",
        "statusRoute"
      ],
      "properties": {
        "publicRoute": {
          "type": "string",
          "pattern": "^/[a-z0-9/_-]*/$"
        },
        "docsRoute": {
          "type": "string",
          "pattern": "^(https://docs\\.mullusi\\.com/[a-z0-9/_-]+(?:\\.html)?|private)$"
        },
        "dashboardRoute": {
          "type": "string",
          "pattern": "^(https://dashboard\\.mullusi\\.com/[a-z0-9/_-]+|/[a-z0-9/_-]+)$"
        },
        "proofRoute": {
          "type": "string",
          "pattern": "^/[a-z0-9/_-]*/$"
        },
        "statusRoute": {
          "type": "string",
          "pattern": "^/[a-z0-9/_-]*/$"
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service",
        "controlPlaneRequired",
        "runtimeWitnessRequired",
        "productionPreflight"
      ],
      "properties": {
        "service": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "controlPlaneRequired": {
          "const": true
        },
        "runtimeWitnessRequired": {
          "const": true
        },
        "productionPreflight": {
          "const": "fail-closed"
        }
      }
    },
    "api": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exposure", "routes"],
      "properties": {
        "exposure": {
          "type": "string",
          "enum": ["none", "planned", "public"]
        },
        "routes": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "api-route.schema.json"
          }
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classes", "privacyBoundary", "retentionPolicy"],
      "properties": {
        "classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "uniqueItems": true
        },
        "privacyBoundary": {
          "type": "string",
          "pattern": "^privacy/[a-z0-9-]+\\.policy\\.json$"
        },
        "retentionPolicy": {
          "type": "string",
          "pattern": "^privacy/[a-z0-9-]+\\.retention\\.json$"
        }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "boundary",
        "claimsAllowed",
        "claimsBlockedUntilVerified",
        "witnesses"
      ],
      "properties": {
        "boundary": {
          "type": "string",
          "pattern": "^proof/[a-z0-9-]+\\.proof\\.json$"
        },
        "claimsAllowed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claimsBlockedUntilVerified": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "witnesses": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string",
            "enum": ["runtime", "contract", "rollback", "privacy", "support", "status"]
          },
          "uniqueItems": true
        }
      }
    },
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compatibilityRegistry",
        "displayOrder",
        "classification",
        "registryStatus",
        "ownerLabel",
        "sourceBoundary",
        "runtimeType",
        "dataType",
        "releaseGate",
        "docsPath",
        "apiPath",
        "evidencePath",
        "failureMode"
      ],
      "properties": {
        "compatibilityRegistry": {
          "type": "boolean"
        },
        "displayOrder": {
          "type": "integer",
          "minimum": 0
        },
        "classification": {
          "type": "string",
          "enum": [
            "public product",
            "public product later",
            "private research product",
            "internal tool",
            "API service",
            "dashboard module",
            "sandbox demo",
            "library/package"
          ]
        },
        "registryStatus": {
          "type": "string",
          "enum": [
            "awaiting-evidence",
            "private-incubation",
            "planned",
            "restricted"
          ]
        },
        "ownerLabel": {
          "type": "string",
          "minLength": 1
        },
        "sourceBoundary": {
          "type": "string",
          "minLength": 1
        },
        "runtimeType": {
          "type": "string",
          "minLength": 1
        },
        "dataType": {
          "type": "string",
          "minLength": 1
        },
        "releaseGate": {
          "type": "string",
          "minLength": 1
        },
        "docsPath": {
          "type": "string",
          "pattern": "^(docs\\.mullusi\\.com(?:/[a-z0-9/_-]+(?:\\.html)?)?|private docs only)$"
        },
        "apiPath": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^(GET|POST) /v[0-9]+/[a-z0-9_{}\\/-]+$"
            },
            {
              "const": "client access to governed API routes"
            },
            {
              "const": "no public endpoint"
            }
          ]
        },
        "evidencePath": {
          "type": "string",
          "enum": ["/proof/", "#evidence"]
        },
        "failureMode": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "releaseGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "promotionPath"],
      "properties": {
        "required": {
          "type": "array",
          "minItems": 7,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "promotionPath": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "private-incubation",
              "internal-alpha",
              "limited-preview",
              "public-beta",
              "production"
            ]
          },
          "minItems": 5,
          "uniqueItems": true
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "emitProductsJson",
        "emitStatusJson",
        "emitSitemap",
        "emitHomepageCard",
        "emitDocsIndex",
        "emitProofIndex"
      ],
      "properties": {
        "emitProductsJson": {
          "type": "boolean"
        },
        "emitStatusJson": {
          "type": "boolean"
        },
        "emitSitemap": {
          "type": "boolean"
        },
        "emitHomepageCard": {
          "type": "boolean"
        },
        "emitDocsIndex": {
          "type": "boolean"
        },
        "emitProofIndex": {
          "type": "boolean"
        }
      }
    }
  }
}

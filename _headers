# Purpose: Cloudflare Pages response headers for the Mullusi public website.
# Governance scope: browser safety headers, static asset cache policy, and public route delivery.
# Dependencies: Cloudflare Pages _headers parser.
# Invariants: headers must not require secrets, break local static rendering, or claim runtime availability.

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-3QYabzdJDybnSoM0XEGQkvX6PIQBb3083ok9i3L9HIk='; style-src 'self'; img-src 'self' data: https://mullusi.com; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'none'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()

/assets/*
  Cache-Control: public, max-age=600

/data/*
  Cache-Control: no-store

/sitemap.xml
  Cache-Control: public, max-age=300

/robots.txt
  Cache-Control: public, max-age=300

/status.json
  Cache-Control: no-store

/.well-known/security.txt
  Cache-Control: public, max-age=300

# Purpose: template production environment variables for Mullusi Govern Cloud.
# Governance scope: runtime identity, API key boundary, proof signing, persistence requirement, CORS boundary, and image selection.
# Dependencies: production secret store, managed PostgreSQL, and container runtime.
# Invariants: this file contains placeholders only; copy to /etc/mullusi/govern.env and replace every placeholder before release.

MULLUSI_IMAGE=ghcr.io/mullusi/mullusi-govern-cloud:latest
MULLUSI_SERVICE_NAME=mullusi-govern-cloud
MULLUSI_API_VERSION=2026.05.v1
MULLUSI_EVALUATOR_VERSION=govern-evaluator.v1
MULLUSI_DEV_API_KEY=replace-with-production-api-key-minimum-32-chars
MULLUSI_PROOF_SIGNING_KEY=replace-with-production-proof-key-minimum-32-chars
MULLUSI_DATABASE_URL=postgresql://mullusi:replace-with-db-password@private-postgres-host:5432/mullusi_govern
MULLUSI_REQUIRE_PERSISTENCE=true
MULLUSI_ALLOWED_ORIGINS=https://mullusi.com,https://www.mullusi.com,https://dashboard.mullusi.com,https://docs.mullusi.com

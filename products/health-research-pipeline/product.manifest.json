{
  "schemaVersion": "1.0.0",
  "id": "health-research-pipeline",
  "name": "Health Research Pipeline",
  "summary": "Restricted research tooling that stays private unless safety, privacy, and authority requirements close.",
  "family": "mullusi",
  "category": "restricted-research",
  "status": "private-incubation",
  "ownership": {
    "owner": "mullusi",
    "supportEmail": "support@mullusi.com"
  },
  "surfaces": {

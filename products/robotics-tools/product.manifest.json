{
  "schemaVersion": "1.0.0",
  "id": "robotics-tools",
  "name": "Robotics Tools",
  "summary": "Engineering tooling for governed robotics simulation, runtime checks, and operator-controlled actions.",
  "family": "mullusi",
  "category": "engineering",
  "status": "private-incubation",
  "ownership": {
    "owner": "mullusi",
    "supportEmail": "support@mullusi.com"
  },
  "surfaces": {
    "publicRoute": "/robotics/",
    "docsRoute": "https://docs.mullusi.com/robotics",
    "dashboardRoute": "https://dashboard.mullusi.com/robotics",
    "proofRoute": "/proof/robotics/",
    "statusRoute": "/status/robotics/"
  },
  "runtime": {
    "service": "robotics-service",
    "controlPlaneRequired": true,
    "runtimeWitnessRequired": true,
    "productionPreflight": "fail-closed"
  },
  "api": {
    "exposure": "planned",
    "routes": [
      {
        "method": "POST",
        "path": "/v1/robotics/simulate",
        "contract": "contracts/robotics/simulate.schema.json"
      }
    ]
  },
  "data": {
    "classes": [
      "robot_tasks",
      "constraints",
      "telemetry",
      "simulation_records",
      "safety_traces"
    ],
    "privacyBoundary": "privacy/robotics.policy.json",
    "retentionPolicy": "privacy/robotics.retention.json"
  },
  "proof": {
    "boundary": "proof/robotics.proof.json",
    "claimsAllowed": [],
    "claimsBlockedUntilVerified": [
      "physical safety floor",
      "simulator witness",
      "operator approval path"
    ],
    "witnesses": [
      "runtime",
      "contract",
      "rollback",
      "privacy"
    ]
  },
  "presentation": {
    "compatibilityRegistry": true,
    "displayOrder": 9,
    "classification": "internal tool",
    "registryStatus": "planned",
    "ownerLabel": "Engineering Systems",
    "sourceBoundary": "private source registry",
    "runtimeType": "engineering runtime tools",
    "dataType": "robot tasks, constraints, telemetry, simulation records, and safety traces",
    "releaseGate": "physical safety floor, simulator witness, operator approval, and rollback plan",
    "docsPath": "docs.mullusi.com/robotics",
    "apiPath": "POST /v1/robotics/simulate",
    "evidencePath": "/proof/",
    "failureMode": "fallback to safety floor and block physical action"
  },
  "releaseGate": {
    "required": [
      "route",
      "docs",
      "api_contract",
      "privacy",
      "runtime_witness",
      "rollback",
      "support",
      "status"
    ],
    "promotionPath": [
      "private-incubation",
      "internal-alpha",
      "limited-preview",
      "public-beta",
      "production"
    ]
  },
  "generation": {
    "emitProductsJson": true,
    "emitStatusJson": true,
    "emitSitemap": true,
    "emitHomepageCard": true,
    "emitDocsIndex": true,
    "emitProofIndex": true
  }
}
